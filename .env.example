# Copy this file to .env for local development (never commit .env)
# All secrets go here; set these same vars in Railway → Variables

# ── AI Providers (at least one required) ─────────────────────────────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
ZHIPU_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Telegram alerts ───────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── NewsAPI (optional, improves fundamental analysis) ────────────────────────
NEWS_API_KEY=

# ── Database (PostgreSQL — Railway provides this automatically) ───────────────
DATABASE_URL=

# ── FRED macroeconomic data (optional) ───────────────────────────────────────
FRED_API_KEY=

# ── MetaTrader 5 (only needed for local Windows execution) ───────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
